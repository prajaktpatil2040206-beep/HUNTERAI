#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# HunterAI — CLI Entry Point
# Usage: sudo hunterai  OR  sudo HUNTERAI
# Starts the Flask server and opens the browser.
# Running with sudo ensures all commands execute without permission issues.
# ═══════════════════════════════════════════════════════════════

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

# ASCII Banner
echo ""
echo -e "\033[0;31m"
cat << 'EOF'
    ██╗  ██╗██╗   ██╗███╗   ██╗████████╗███████╗██████╗  █████╗ ██╗
    ██║  ██║██║   ██║████╗  ██║╚══██╔══╝██╔════╝██╔══██╗██╔══██╗██║
    ████████║██║   ██║██╔██╗ ██║   ██║   █████╗  ██████╔╝███████║██║
    ██╔══██║██║   ██║██║╚██╗██║   ██║   ██╔══╝  ██╔══██╗██╔══██║██║
    ██║  ██║╚██████╔╝██║ ╚████║   ██║   ███████╗██║  ██║██║  ██║██║
    ╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═══╝   ╚═╝   ╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝
EOF
echo -e "\033[0m"
echo -e "\033[0;36m    🛡  Autonomous AI-Powered Bug Bounty Platform\033[0m"
echo -e "\033[0;33m    \"Think Like a Hacker. Hunt Like a Machine.\"\033[0m"
echo ""

# Check root
if [ "$EUID" -ne 0 ]; then
    echo -e "\033[1;33m[!] Running without root. Some commands may require sudo.\033[0m"
    echo -e "\033[1;33m    Recommended: sudo hunterai\033[0m"
    echo ""
fi

# Activate venv if exists
if [ -f "$SCRIPT_DIR/venv/bin/activate" ]; then
    source "$SCRIPT_DIR/venv/bin/activate"
fi

cd "$SCRIPT_DIR"

echo -e "\033[0;32m    🌐 Starting server at http://localhost:5000\033[0m"
echo -e "\033[0;32m    📡 Press Ctrl+C to stop\033[0m"
echo ""

# Start Flask app
python3 app.py
